# Capstone News - Docker environment example
# Use this when running the project via Docker.
# Copy to: .env  (or run docker with --env-file .env.docker)

SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Database from inside Docker
# On Docker Desktop (Windows/Mac), use host.docker.internal to reach services on your host machine.
DB_NAME=capstone_news
DB_USER=root
DB_PASSWORD=your_mariadb_password
DB_HOST=host.docker.internal
DB_PORT=3306

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=no-reply@capstonenews.local