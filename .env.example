# Django settings for Capstone News project.
# MariaDB connection settings and other environment variables are defined here.

SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

DB_NAME=capstone_news
DB_USER=root
DB_PASSWORD=your_mariadb_password
DB_HOST=127.0.0.1
DB_PORT=3306

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=no-reply@capstonenews.local

# Docker-specific overrides
# When running in Docker, the database host should be set to 'host.docker.internal'
# to allow the container to connect to the host's database service.
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

DB_NAME=capstone_news
DB_USER=root
DB_PASSWORD=your_mariadb_password
DB_HOST=host.docker.internal
DB_PORT=3306

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=no-reply@capstonenews.local